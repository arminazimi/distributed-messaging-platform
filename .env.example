LISTEN_ADDR=:8080
APP_NAME=distributed-messaging-platform

DB_USER_NAME=message_user
DB_PASSWORD=message_pass
DB_HOST=localhost
DB_PORT=3306
DB_NAME=messaging_platform

RABBIT_URI=amqp://rabbit_user:rabbit_pass@localhost:5672/
RABBIT_MESSAGE_EXCHANGE=message_exchange
EXPRESS_QUEUE=message_express
NORMAL_QUEUE=message_normal

OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true

GLOBAL_RATE_LIMIT_RPS=1000
GLOBAL_RATE_LIMIT_BURST=1000
USER_RATE_LIMIT_RPS=20
USER_RATE_LIMIT_BURST=20
